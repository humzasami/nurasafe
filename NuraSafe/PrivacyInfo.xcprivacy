<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- No data is collected from users and sent to servers. -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array/>

    <!-- No tracking of users across apps or websites. -->
    <key>NSPrivacyTracking</key>
    <false/>

    <!-- No tracking domains. -->
    <key>NSPrivacyTrackingDomains</key>
    <array/>

    <!-- Required Reason APIs used by NuraSafe -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array>

        <!-- UserDefaults: used to persist app settings (text size, language, haptics),
             active emergency mode, terms acceptance state, and pinned messages.
             All data stays on-device and is never transmitted. -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <!-- CA92.1: Access info from the same app that wrote it -->
                <string>CA92.1</string>
            </array>
        </dict>

    </array>
</dict>
</plist>
